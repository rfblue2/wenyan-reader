# Copy to `.env` in the repo root (gitignored) or export these in your shell.
# `uv run` loads `.env` automatically.

# Model provider: mock (default) | minimax | anthropic
WENYAN_MODEL_PROVIDER=minimax

# MiniMax (cost-effective for development; get a key at https://platform.minimax.io/)
MINIMAX_API_KEY=

# Optional: override the model for the active provider (defaults are in config/preprocessing.yaml)
# WENYAN_MODEL=MiniMax-M2.5-highspeed

# Anthropic (production-quality preprocessing)
# WENYAN_MODEL_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
